---
layout: page.njk
permalink: /blog/index.html
title: Writing
description: Essays, photo stories, and observations on nature and the natural world.
heroImage: "https://images.unsplash.com/photo-1441974231531-c6227db76b6e?q=80&w=2560&auto=format&fit=crop"
---

<div class="home-hero-wrapper">
  <div class="home-slideshow-fs">
    <img src="{{ heroImage }}" alt="{{ title }}" style="width: 100%; height: 100%; object-fit: cover; display: block;">
  </div>
  <section class="home-hero-overlay">
    <h1 class="home-title">{{ title }}</h1>
    <p class="home-intro">{{ description }}</p>
  </section>
</div>

{% if collections.posts and collections.posts.length %}
<div class="post-grid">
  {% for post in collections.posts %}
  <a href="{{ post.url | url }}" class="post-card">
    <div class="post-card-img">
      {% if post.data.coverImage %}
      <img src="{{ post.data.coverImage }}" alt="{{ post.data.title }}" loading="lazy">
      {% else %}
      <div class="post-card-placeholder"></div>
      {% endif %}
    </div>
    <div class="post-card-body">
      <h2>{{ post.data.title }}</h2>
      <div class="post-meta">
        {% if post.date %}<time datetime="{{ post.date | isoDate }}">{{ post.date | readableDate }}</time>{% endif %}
      </div>
      {% if post.data.description %}<p class="post-card-desc">{{ post.data.description }}</p>{% endif %}
    </div>
  </a>
  {% endfor %}
</div>
{% else %}
<p class="empty-state">No posts yet.</p>
{% endif %}
