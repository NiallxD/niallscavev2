---
layout: base.njk
title: Home
description: The personal site of Niall Bell — nature photographer, writer, and environmentalist.
---
<div class="home">
  <section class="home-hero">
    <h1>Niall's Cave</h1>
    <p class="hero-lead">Nature, photography, and writing. A glimpse into how I perceive the world.</p>
  </section>

  {% if collections.posts and collections.posts.length %}
  <section class="recent-posts">
    <h2>Recent writing</h2>
    <ul class="post-list">
      {% for post in collections.posts %}
      <li>
        <a href="{{ post.url }}">{{ post.data.title }}</a>
        {% if post.date %}
        <span class="post-date">{{ post.date | readableDate }}</span>
        {% endif %}
      </li>
      {% endfor %}
    </ul>
  </section>
  {% endif %}
</div>
