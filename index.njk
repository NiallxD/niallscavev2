---
layout: base.njk
title: Home
description: The personal site of Niall Bell — nature photographer, writer, and environmentalist.
---

<section class="home-hero">
  <h1>Niall Bell</h1>
  <p class="hero-lead">
    Nature photographer and environmentalist, documenting UK wildlife and wild places.
    Sharing the beauty of the natural world through photography and writing.
  </p>
  <div class="hero-actions">
    <a href="/photography" class="btn btn-primary">Photography</a>
    <a href="/blog" class="btn btn-secondary">Writing</a>
    <a href="/about-me" class="btn btn-secondary">About</a>
  </div>
</section>

<div class="home-sections">
  <div class="home-section">
    <h2>Recent writing</h2>
    {% if collections.posts and collections.posts.length %}
    <ul class="post-list">
      {% for post in collections.posts | slice(0, 6) %}
      <li>
        <a href="{{ post.url }}">
          <span>{{ post.data.title }}</span>
          {% if post.date %}
          <span class="post-date">{{ post.date | readableDate }}</span>
          {% endif %}
        </a>
      </li>
      {% endfor %}
    </ul>
    <a href="/blog" class="view-all">All writing →</a>
    {% else %}
    <p style="font-size:0.9rem;color:var(--color-muted)">Posts coming soon.</p>
    {% endif %}
  </div>

  <div class="home-section">
    <h2>Photography</h2>
    {% if collections.galleries and collections.galleries.length %}
    <div class="home-gallery-preview">
      {% for gallery in collections.galleries | slice(0, 4) %}
      {% if gallery.data['header-image'] %}
      <a href="{{ gallery.url }}" title="{{ gallery.data.title }}">
        <img src="{{ gallery.data['header-image'] }}" alt="{{ gallery.data.title }}" loading="lazy">
      </a>
      {% endif %}
      {% endfor %}
    </div>
    <a href="/photography" class="view-all">All galleries →</a>
    {% else %}
    <p style="font-size:0.9rem;color:var(--color-muted)">Galleries coming soon.</p>
    {% endif %}
  </div>
</div>
