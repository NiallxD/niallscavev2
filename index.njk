---
layout: page.njk
title: Home
description: The personal site of Niall Bell — nature photographer, writer, and environmentalist.
---

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">

<div class="home-hero-wrapper">
  {% if collections.homeGallery and collections.homeGallery.length %}
  {% set slides = collections.homeGallery[0].content | extractImages %}
  {% if slides.length %}
  <div class="home-slideshow-fs">
    <div class="swiper home-swiper">
      <div class="swiper-wrapper">
        {% for img in slides %}
        <div class="swiper-slide">
          <img src="{{ img.src }}" alt="{{ img.alt }}" loading="lazy">
        </div>
        {% endfor %}
      </div>
      <div class="swiper-pagination"></div>
      <div class="swiper-button-prev"></div>
      <div class="swiper-button-next"></div>
    </div>
  </div>
  {% endif %}
  {% endif %}

  <section class="home-hero-overlay">
    <h1 class="home-title">Niall Bell</h1>
    <p class="home-intro">
      I'm Niall — a nature photographer and environmentalist based in the UK. I spend my time
      documenting the wildlife and wild places of Britain and beyond, sharing the beauty of the
      natural world through photography and writing.
    </p>
  </section>
</div>

{% if collections.posts and collections.posts.length %}
<div class="home-posts">
  <div class="home-block-header">
    <h2 class="section-label">Recent writing</h2>
    <a href="{{ '/blog/' | url }}" class="view-all">All writing →</a>
  </div>
  <div class="post-grid">
    {% for post in collections.posts | limit(3) %}
    <a href="{{ post.url | url }}" class="post-card">
      <div class="post-card-img">
        {% if post.data.coverImage %}
        <img src="{{ post.data.coverImage }}" alt="{{ post.data.title }}" loading="lazy">
        {% else %}
        <div class="post-card-placeholder"></div>
        {% endif %}
      </div>
      <div class="post-card-body">
        <h2>{{ post.data.title }}</h2>
        <div class="post-meta">
          {% if post.date %}<time datetime="{{ post.date | isoDate }}">{{ post.date | readableDate }}</time>{% endif %}
        </div>
      </div>
    </a>
    {% endfor %}
  </div>
</div>
{% endif %}

<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
<script>
  new Swiper('.home-swiper', {
    loop: true,
    autoplay: { delay: 5000, pauseOnMouseEnter: true, disableOnInteraction: false },
    speed: 800,
    pagination: { el: '.swiper-pagination', clickable: true },
    navigation: { nextEl: '.swiper-button-next', prevEl: '.swiper-button-prev' },
  });
</script>
