---
layout: page.njk
title: Home
description: The personal site of Niall Bell, a nature photographer, writer, and environmentalist from England, living in BC.
---

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
<link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.5.3/dist/MarkerCluster.css"/>
<link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.5.3/dist/MarkerCluster.Default.css"/>

<div class="home-hero-wrapper">
  {% if collections.homeGallery and collections.homeGallery.length %}
  {% set slides = collections.homeGallery[0].content | extractImages %}
  {% if slides.length %}
  <div class="home-slideshow-fs">
    <div class="swiper home-swiper">
      <div class="swiper-wrapper">
        {% for img in slides %}
        <div class="swiper-slide">
          <img src="{{ img.src }}" alt="{{ img.alt }}" loading="lazy">
        </div>
        {% endfor %}
      </div>
      <div class="swiper-button-prev"></div>
      <div class="swiper-button-next"></div>
    </div>
  </div>
  {% endif %}
  {% endif %}

  <section class="home-hero-overlay">
    <h1 class="home-title">Niall Bell</h1>
    <p class="home-intro">
      I'm Niall, a nature photographer and environmentalist from the UK, based in British Columbia, Canada. I spend my time documenting the wildlife and wild places of my surroundings and sharing the beauty of the natural world through photography and writing.
    </p>
    <div class="scroll-hint">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 13l5 5 5-5M7 6l5 5 5-5"/></svg>
    </div>
  </section>
</div>

{% if collections.featuredGalleries and collections.featuredGalleries.length %}
<div class="home-posts">
  <div class="home-block-header">
    <p class="section-label">Featured Galleries</p>
    <a href="{{ '/photography/' | url }}" class="view-all">All photography →</a>
  </div>
  <div class="story-list">
    {% for gallery in collections.featuredGalleries | limit(3) %}
    <a href="{{ gallery.url | url }}" class="story-card">
      <div class="story-card-img">
        {% if gallery.data.coverImage %}
        <img src="{{ gallery.data.coverImage }}" alt="{{ gallery.data.title }}" loading="lazy">
        {% endif %}
      </div>
      <div class="story-card-body">
        <div class="post-card-meta">
          {% if gallery.date %}<time class="post-card-date" datetime="{{ gallery.date | isoDate }}">{{ gallery.date | readableDate }}</time>{% endif %}
          {% if gallery.data.tags %}
          <div class="post-card-tags">
            {% for tag in gallery.data.tags | limit(2) %}<span class="tag">{{ tag }}</span>{% endfor %}
          </div>
          {% endif %}
        </div>
        <div class="story-card-title">{{ gallery.data.title }}</div>
        {% if gallery.data.excerpt %}
        <div class="story-card-desc">{{ gallery.data.excerpt }}</div>
        {% endif %}
      </div>
    </a>
    {% endfor %}
  </div>
</div>
{% endif %}

{% if collections.posts and collections.posts.length %}
<div class="home-posts">
  <div class="home-block-header">
    <p class="section-label">Recent writing</p>
    <a href="{{ '/blog/' | url }}" class="view-all">All writing →</a>
  </div>
  <div class="story-list">
    {% for post in collections.posts | limit(3) %}
    <a href="{{ post.url | url }}" class="story-card">
      <div class="story-card-img">
        {% if post.data.coverImage %}
        <img src="{{ post.data.coverImage }}" alt="{{ post.data.title }}" loading="lazy">
        {% else %}
        <div class="post-card-placeholder" style="width: 100%; height: 100%; background: var(--color-surface);"></div>
        {% endif %}
      </div>
      <div class="story-card-body">
        <div class="post-card-author">Niall Bell</div>
        <div class="post-card-meta">
          {% if post.date %}<time class="post-card-date" datetime="{{ post.date | isoDate }}">{{ post.date | readableDate }}</time>{% endif %}
          {% if post.data.tags %}
          <div class="post-card-tags">
            {% for tag in post.data.tags | limit(2) %}<span class="tag">{{ tag }}</span>{% endfor %}
          </div>
          {% endif %}
        </div>
        <div class="story-card-title">{{ post.data.title }}</div>
        {% if post.data.excerpt %}<div class="story-card-desc">{{ post.data.excerpt }}</div>{% endif %}
      </div>
    </a>
    {% endfor %}
  </div>
</div>
{% endif %}

{% set mapPage = collections.maps | first %}
{% if mapPage %}
{% set mapPins = mapPage.content | parseMapBlocks %}
{% if mapPins.length %}
<div class="home-map-row">
    <div class="home-map-col">
      <div class="home-block-header">
        <p class="section-label">Photo Map</p>
        <a href="{{ '/photo-map/' | url }}" class="view-all">Full map →</a>
      </div>
      <div id="home-photo-map"></div>
    </div>
    <aside class="home-reading-col">
      <div class="home-block-header">
        <p class="section-label">Reading Now</p>
        <a href="{{ '/bookshelf/' | url }}" class="view-all">Bookshelf →</a>
      </div>
      {% set currentBook = collections.currentlyReading | first %}
      {% if currentBook %}
      <a href="{{ '/bookshelf/' | url }}" class="home-reading-card">
        {% if currentBook.data.heroImage %}
        <img class="home-reading-cover" src="{{ currentBook.data.heroImage }}" alt="{{ currentBook.data.title }}">
        {% endif %}
        <div class="home-reading-info">
          <p class="home-reading-title">{{ currentBook.data.title }}</p>
          {% if currentBook.data.author %}<p class="home-reading-author">{{ currentBook.data.author }}</p>{% endif %}
          {% if currentBook.data.tags %}
          <div class="home-reading-tags">
            {% for tag in currentBook.data.tags | limit(3) %}<span class="tag">{{ tag }}</span>{% endfor %}
          </div>
          {% endif %}
        </div>
      </a>
      {% else %}
      <div class="home-reading-card home-reading-card--empty">
        <p class="home-reading-empty">Nothing on the shelf right now.</p>
      </div>
      {% endif %}
    </aside>
</div>
{% endif %}
{% endif %}

<div class="home-prints-row">
  <aside class="home-project-col">
    <div class="home-block-header">
      <p class="section-label">Current Project</p>
      <a href="{{ '/side-projects/' | url }}" class="view-all">Projects →</a>
    </div>
    {% set currentProject = collections.currentProject | first %}
    {% if currentProject %}
    <a href="{{ currentProject.url | url }}" class="home-reading-card">
      {% if currentProject.data.coverImage or currentProject.data.heroImage %}
      <img class="home-reading-cover" src="{{ currentProject.data.coverImage or currentProject.data.heroImage }}" alt="{{ currentProject.data.title }}">
      {% endif %}
      <div class="home-reading-info">
        <p class="home-reading-title">{{ currentProject.data.title }}</p>
        {% if currentProject.data.excerpt %}<p class="home-reading-excerpt">{{ currentProject.data.excerpt }}</p>{% endif %}
        {% if currentProject.data.tags %}
        <div class="home-reading-tags">
          {% for tag in currentProject.data.tags | limit(3) %}<span class="tag">{{ tag }}</span>{% endfor %}
        </div>
        {% endif %}
      </div>
    </a>
    {% else %}
    <div class="home-reading-card home-reading-card--empty">
      <p class="home-reading-empty">No active project right now.</p>
    </div>
    {% endif %}
  </aside>
  <div class="home-prints-col">
    <div class="home-block-header">
