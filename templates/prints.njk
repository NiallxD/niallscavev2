<!-- Print Enquiry Modal -->
<div class="enquiry-backdrop" id="enquiry-backdrop" aria-hidden="true"></div>
<div class="enquiry-modal" id="enquiry-modal" role="dialog" aria-modal="true" aria-label="Print enquiry form">
  <button class="enquiry-close" id="enquiry-close" aria-label="Close">
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
  </button>

  <div class="enquiry-form-wrap" id="enquiry-form-wrap">
    <p class="enquiry-eyebrow">Print Enquiry</p>
    <h2 class="enquiry-heading">Get in Touch</h2>
    <p class="enquiry-subhead">Tell me which photograph you're interested in and I'll come back to you with sizing, pricing, and the conservation charity your purchase will support.</p>

    <form class="enquiry-form" id="enquiry-form" novalidate>
      <input type="hidden" name="access_key" value="defc3825-081d-4a5a-b0cb-69af74ae3e4c">
      <input type="hidden" name="subject" value="Print Enquiry from niallbell.com">
      <input type="checkbox" name="botcheck" style="display:none">

      <div class="enquiry-field">
        <label class="enquiry-label" for="enq-name">Your Name</label>
        <input class="enquiry-input" type="text" id="enq-name" name="name" autocomplete="name" placeholder="Jane Smith" required>
      </div>

      <div class="enquiry-field">
        <label class="enquiry-label" for="enq-email">Email Address</label>
        <input class="enquiry-input" type="email" id="enq-email" name="email" autocomplete="email" placeholder="jane@example.com" required>
      </div>

      <div class="enquiry-field">
        <label class="enquiry-label" for="enq-photo">Photograph</label>
        <input class="enquiry-input" type="text" id="enq-photo" name="photo" placeholder="e.g. Bengal Tiger at Dusk" required>
      </div>

      <div class="enquiry-field">
        <label class="enquiry-label" for="enq-notes">Anything else? <span class="enquiry-optional">Optional</span></label>
        <textarea class="enquiry-input enquiry-textarea" id="enq-notes" name="message" placeholder="Preferred size, framing questions, timeline…" rows="4"></textarea>
      </div>

      <p class="enquiry-error" id="enquiry-error" aria-live="polite"></p>

      <button type="submit" class="enquiry-submit" id="enquiry-submit">
        <span class="enquiry-submit-text">Send Enquiry</span>
        <svg class="enquiry-spinner" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg>
      </button>
    </form>
  </div>

  <div class="enquiry-thanks" id="enquiry-thanks" aria-live="polite">
    <div class="enquiry-thanks-icon">
      <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
    </div>
    <h2 class="enquiry-thanks-heading">Message Sent</h2>
    <p class="enquiry-thanks-body">Thanks — I'll be in touch soon with details on sizing, pricing, and the conservation charity your purchase will support.</p>
    <button type="button" class="enquiry-thanks-close" id="enquiry-thanks-close">Close</button>
  </div>
</div>

<script>
  (() => {
    const open = document.getElementById('enquiry-open');
    const close = document.getElementById('enquiry-close');
    const modal = document.getElementById('enquiry-modal');
    const backdrop = document.getElementById('enquiry-backdrop');
    const form = document.getElementById('enquiry-form');
    const submit = document.getElementById('enquiry-submit');
    const errorEl = document.getElementById('enquiry-error');
    const formWrap = document.getElementById('enquiry-form-wrap');
    const thanks = document.getElementById('enquiry-thanks');
    const thanksClose = document.getElementById('enquiry-thanks-close');

    const openModal = () => {
      modal.classList.add('open');
      backdrop.classList.add('open');
      document.body.style.overflow = 'hidden';
      modal.querySelector('#enq-name').focus();
    };

    const closeModal = () => {
      modal.classList.remove('open');
      backdrop.classList.remove('open');
      document.body.style.overflow = '';
    };

    open.addEventListener('click', openModal);
    close.addEventListener('click', closeModal);
    thanksClose.addEventListener('click', closeModal);
    backdrop.addEventListener('click', closeModal);

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && modal.classList.contains('open')) closeModal();
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      errorEl.textContent = '';

      const data = new FormData(form);
      submit.classList.add('loading');
      submit.disabled = true;

      try {
        const res = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          body: data
        });
        const json = await res.json();

        if (json.success) {
          formWrap.style.display = 'none';
          thanks.classList.add('visible');
        } else {
          errorEl.textContent = json.message || 'Something went wrong — please try again.';
        }
      } catch {
        errorEl.textContent = 'Could not send — please check your connection and try again.';
      } finally {
        submit.classList.remove('loading');
        submit.disabled = false;
      }
    });
  })();
</script>
