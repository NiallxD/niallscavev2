---
layout: page.njk
---
{% if heroImage %}
<div class="home-hero-wrapper">
  <div class="home-slideshow-fs">
    <img src="{{ heroImage }}" alt="{{ title }}" style="width:100%;height:100%;object-fit:cover;display:block;">
  </div>
  <section class="home-hero-overlay">
    <h1 class="home-title">{{ title }}</h1>
    {% if description %}<p class="home-intro">{{ description }}</p>{% endif %}
    <div class="scroll-hint">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 13l5 5 5-5M7 6l5 5 5-5"/></svg>
    </div>
  </section>
</div>
{% endif %}

<div class="standard-page">

  {% if not heroImage %}
  <header class="page-header">
    <h1>{{ title }}</h1>
  </header>
  {% endif %}

  <p class="section-label">You've Found My Bag!</p>

  <div class="experience-card">
    <div class="exp-sidebar">
      <div class="exp-company">🧳 Contact Me</div>
      <div class="exp-job-title">Please get in touch via email or phone before sending luggage</div>
    </div>
    <div class="exp-main">
      <ul>
        <li>
          <strong>Email</strong><br>
          <a href="mailto:niall@niallbell.com" style="color:var(--color-link);">niall@niallbell.com</a>
        </li>
        <li>
          <strong>Phone (UK)</strong><br>
          <a href="tel:+447949489400" style="color:var(--color-link);">+44 7949 489 400</a>
        </li>
        <li>
          <strong>Phone (CA)</strong><br>
          <a href="tel:+12365122371" style="color:var(--color-link);">+1 (236) 512-2371</a>
        </li>
      </ul>
    </div>
  </div>

  <p style="font-size:0.78rem;color:var(--color-muted);margin-top:1.25rem;margin-bottom:3rem;">Last updated: April 2025</p>

  <div class="callout callout-warning" style="display:flex;gap:1rem;align-items:flex-start;">
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:2px;color:#f59e0b;"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
    <div>
      <p class="callout-title">Hello Visitor!</p>
      <p style="margin:0;font-size:0.95rem;color:var(--color-secondary);">You're probably here because you stumbled on this page by accident, or I've lost some luggage and you've found it. If you found a bag, please read on. If you're here by accident, feel free to check out some of my <a href="/">actually interesting pages</a>.</p>
    </div>
  </div>

</div>
