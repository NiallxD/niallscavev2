---
layout: page.njk
---
{% if heroImage %}
<div class="home-hero-wrapper">
  <div class="home-slideshow-fs">
    <img src="{{ heroImage }}" alt="{{ title }}" class="img-cover">
  </div>
  <section class="home-hero-overlay">
    <h1 class="home-title">{{ title }}</h1>
    <p class="home-intro">{{ description }}</p>
  </section>
</div>
{% endif %}

<div class="standard-page">

  <!-- SERVICES -->
  <p class="section-label">Services</p>
  <div class="services-grid">

    <div class="service-card">
      <div class="service-card-icon-wrap">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="5" r="1"/><path d="M5.5 17.5l2-5 2.5 2 2-4 2.5 5 2-3"/><path d="M3 21h18"/></svg>
      </div>
      <h3 class="service-card-title">Nature Walks</h3>
      <p class="service-card-desc">Guided walks in the Sea-to-Sky region focused on wildlife observation and ecology. Suitable for all ages and experience levels — whether you want to find your first bird or deepen an existing interest in the natural world.</p>
      <a href="/nature-walks/" class="service-card-btn">Learn more</a>
    </div>

    <div class="service-card">
      <div class="service-card-icon-wrap">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
      </div>
      <h3 class="service-card-title">Photography Workshops</h3>
      <p class="service-card-desc">Small-group and one-to-one workshops covering wildlife and landscape photography in the field. From camera settings and composition to finding and approaching subjects — I'll help you take images you're proud of.</p>
      <a href="/photography-workshops/" class="service-card-btn">Learn more</a>
    </div>

  </div>

  {% if sectionLabel %}
  <p class="section-label">{{ sectionLabel }}</p>
  {% endif %}

  {% if content %}
  <div class="post-content">{{ content | safe }}</div>
  {% endif %}

  {% if collections.projects and collections.projects.length %}
  <div class="projects-list">
    {% for project in collections.projects %}
    <div class="project-card-wrapper">
      <a href="{{ project.data.link | default('#') }}" class="project-card-full" target="_blank" rel="noopener">
        <div class="project-card-body">
          <div class="project-card-icon-wrap">
            {% if project.data.icon == 'chart' %}
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/><line x1="2" y1="20" x2="22" y2="20"/></svg>
            {% elif project.data.icon == 'phone' %}
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
            {% elif project.data.icon == 'map' %}
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6"/><line x1="8" y1="2" x2="8" y2="18"/><line x1="16" y1="6" x2="16" y2="22"/></svg>
            {% elif project.data.icon == 'walk' %}
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 17l4-8 4 4 4-6 4 10"/></svg>
            {% else %}
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
            {% endif %}
          </div>
          <div class="post-card-author">{{ project.data.author | default("Niall Bell") }}</div>
          <div class="post-card-meta">
            {% if project.date %}<time class="post-card-date" datetime="{{ project.date | isoDate }}">{{ project.date | readableDate }}</time>{% endif %}
            {% if project.data.tags %}
            <div class="post-card-tags">
              {% for tag in project.data.tags | limit(3) %}<span class="tag">{{ tag }}</span>{% endfor %}
            </div>
            {% endif %}
          </div>
          <h2 class="project-title">{{ project.data.title }}</h2>
          {% if project.data.description %}<p class="project-desc">{{ project.data.description }}</p>{% endif %}
          <span class="project-link-btn">Visit Project →</span>
        </div>
      </a>
    </div>
    {% endfor %}
  </div>
  {% else %}
  <p class="empty-state">No projects found.</p>
  {% endif %}
</div>
