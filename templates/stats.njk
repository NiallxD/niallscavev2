---
layout: base.njk
---

<style>
  .stats-container {
    max-width: 1000px;
    margin: 100px auto 4rem;
    padding: 0 2rem;
  }
  .stats-header {
    margin-bottom: 3rem;
  }
  
  /* Overview Cards */
  .stats-overview-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr 1fr;
    gap: 1.25rem;
    margin-bottom: 4rem;
  }
  .stat-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    transition: border-color 0.2s ease;
  }
  .stat-card--large {
    grid-column: span 4;
    padding: 2rem;
    align-items: center;
  }
  .stat-card--main {
    grid-column: span 1;
    padding: 1.25rem;
  }
  .stat-card:hover {
    border-color: var(--color-accent);
  }
  .stat-card-label {
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    color: var(--color-muted);
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }
  .stat-card-value {
    font-size: 1.4rem;
    font-weight: 800;
    color: var(--color-accent);
  }
  .stat-card--large .stat-card-value {
    font-size: 3rem;
  }
  .stat-growth {
    font-size: 0.85rem;
    font-weight: 600;
    color: #52b788;
    margin-top: 4px;
  }

  /* Table Section */
  .detailed-stats-section {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }
  .stats-filter-row {
    margin-bottom: 1.5rem;
    display: flex;
    gap: 1rem;
  }
  .stats-table-wrapper {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
  }
  .stats-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
  }
  .stats-table th {
    text-align: left;
    padding: 1rem 1.5rem;
    background: var(--color-footer-bg);
    border-bottom: 1px solid var(--color-border);
    font-size: 0.7rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-muted);
  }
  .stats-table td {
    padding: 1rem 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }
  .stats-table .count-cell {
    font-weight: 700;
    color: var(--color-accent);
    text-align: right;
  }
  
  @media (max-width: 900px) {
    .stats-overview-grid { grid-template-columns: 1fr 1fr; }
    .stat-card--large { grid-column: span 2; }
  }
</style>

<div class="stats-container">
  <header class="stats-header">
    <p class="section-label" style="color: var(--color-accent)">Transparency Report</p>
    <h1 class="page-title">The Vault Stats</h1>
    <p class="home-stats-text" style="font-size: 1rem; color: var(--color-text); font-weight: 600;">100% Private, Zero-Tracking Overview</p>
    <p class="home-stats-text">This page is a live look at my site activity. Unlike most websites, niallbell.com uses no cookies, no profiling, and no third-party trackers. Data is fetched directly from an independent counter API. I don't see who you are, what device you use, or where you've been on the web. I only see that a human being took the time to visit a page.</p>
  </header>

  <!-- High Level Overview -->
  <div class="stats-overview-grid">
    <div class="stat-card stat-card--large">
      <p class="stat-card-label">Total Site Visitors</p>
      <p id="total-visits" class="stat-card-value">...</p>
      <div id="total-growth" class="stat-growth"></div>
    </div>
    
    <!-- Main Hubs (Will be populated by JS) -->
    <div id="hub-cards-container" style="display: contents;">
      <div class="stat-card stat-card--main"><p class="stat-card-label">Home</p><p class="stat-card-value" id="val-home">...</p></div>
      <div class="stat-card stat-card--main"><p class="stat-card-label">Photography</p><p class="stat-card-value" id="val-photography">...</p></div>
      <div class="stat-card stat-card--main"><p class="stat-card-label">Writing</p><p class="stat-card-value" id="val-blog">...</p></div>
      <div class="stat-card stat-card--main"><p class="stat-card-label">Projects</p><p class="stat-card-value" id="val-side-projects">...</p></div>
      <div class="stat-card stat-card--main"><p class="stat-card-label">Bookshelf</p><p class="stat-card-value" id="val-bookshelf">...</p></div>
      <div class="stat-card stat-card--main"><p class="stat-card-label">About</p><p class="stat-card-value" id="val-about-me">...</p></div>
      <div class="stat-card stat-card--main"><p class="stat-card-label">Prints</p><p class="stat-card-value" id="val-prints">...</p></div>
      <div class="stat-card stat-card--main"><p class="stat-card-label">Video</p><p class="stat-card-value" id="val-videography">...</p></div>
    </div>
  </div>

  <!-- Detailed Table -->
  <div class="detailed-stats-section">
    <div class="home-block-header">
      <p class="section-label">Detailed Breakdown</p>
    </div>
    
    <div class="stats-filter-row">
      <input type="text" id="stats-search" placeholder="Search pages..." style="flex: 1; padding: 0.75rem 1rem; border-radius: var(--radius-sm); border: 1px solid var(--color-border); background: var(--color-surface); color: var(--color-text); font-family: var(--font-sans); font-size: 0.9rem;">
      <select id="stats-sort" style="padding: 0.75rem 1rem; border-radius: var(--radius-sm); border: 1px solid var(--color-border); background: var(--color-surface); color: var(--color-text); font-family: var(--font-sans); font-size: 0.9rem; cursor: pointer;">
        <option value="visits">Sort by Visits</option>
        <option value="name">Sort by Name</option>
      </select>
    </div>

    <div class="stats-table-wrapper">
      <table class="stats-table">
        <thead>
          <tr>
            <th>Page</th>
            <th style="text-align: right">Unique Visits</th>
          </tr>
        </thead>
        <tbody id="page-stats-body">
          <tr>
            <td colspan="2" style="text-align: center; padding: 2rem;">
              <button onclick="loadAllRemainingPages()" class="stats-btn" style="background: var(--color-accent); color: #fff; border: none; padding: 0.8rem 1.5rem; border-radius: var(--radius-sm); cursor: pointer; font-weight: 600;">
                Load data for all posts & galleries
              </button>
            </td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</div>

<script>
  const mainHubs = [
    { id: 'home', label: 'Home Page' },
    { id: 'photography', label: 'Photography' },
    { id: 'blog', label: 'Writing (All)' },
    { id: 'about-me', label: 'About Me' },
    { id: 'prints', label: 'Prints' },
    { id: 'videography', label: 'Videography' },
    { id: 'side-projects', label: 'Projects' },
    { id: 'bookshelf', label: 'Bookshelf' }
  ];

  const otherPages = [
    {%- for p in collections.all %}
    {%- if p.url and not p.data.eleventyExcludeFromCollections %}
    {%- set isMain = false %}
    {%- if p.url == '/' or p.url == '/photography/' or p.url == '/blog/' or p.url == '/about-me/' or p.url == '/prints/' or p.url == '/videography/' or p.url == '/side-projects/' or p.url == '/bookshelf/' %}
      {%- set isMain = true %}
    {%- endif %}
    {%- if not isMain %}
    { 
      id: {{ p.url | replace("/", "") | replace("/", "-") or "home" | dump | safe }}, 
      label: {{ (p.data.title or p.url) | dump | safe }},
      url: {{ p.url | dump | safe }}
    },
    {%- endif %}
    {%- endif %}
    {%- endfor %}
  ].filter((v, i, a) => a.findIndex(t => t.id === v.id) === i);

  let fullStatsList = [];

  async function loadInitialStats() {
    // 1. Load Total
    try {
      const res = await fetch('https://api.counterapi.dev/v1/niallbell/visits/');
      const data = await res.json();
      const count = data.count || 0;
      document.getElementById('total-visits').innerText = count.toLocaleString();
      
      // Growth check
      const lastCount = localStorage.getItem('nb_last_total');
      if (lastCount && count > parseInt(lastCount)) {
        document.getElementById('total-growth').innerText = `+${count - parseInt(lastCount)} today`;
      }
      localStorage.setItem('nb_last_total', count);
    } catch(e) {}

    // 2. Load Main Hubs
    for (const hub of mainHubs) {
      fetch(`https://api.counterapi.dev/v1/niallbell/page-${hub.id}/`)
        .then(res => res.json())
        .then(data => {
          const el = document.getElementById(`val-${hub.id}`);
          if (el) el.innerText = (data.count || 0).toLocaleString();
          fullStatsList.push({...hub, count: data.count || 0});
        })
        .catch(() => {
          const el = document.getElementById(`val-${hub.id}`);
          if (el) el.innerText = '0';
        });
    }
  }

  async function loadAllRemainingPages() {
    const tbody = document.getElementById('page-stats-body');
    tbody.innerHTML = '<tr><td colspan="2" style="text-align: center; padding: 2rem; color: var(--color-muted);">Fetching individual post data... this takes ~2 mins due to API limits.</td></tr>';
    
    const chunkSize = 15;
    for (let i = 0; i < otherPages.length; i += chunkSize) {
      const chunk = otherPages.slice(i, i + chunkSize);
      const results = await Promise.all(
        chunk.map(page => fetch(`https://api.counterapi.dev/v1/niallbell/page-${page.id}/`).then(res => res.json()).then(d => ({...page, count: d.count || 0})).catch(() => ({...page, count: 0})))
      );
      fullStatsList.push(...results);
      renderTable();
      if (i + chunkSize < otherPages.length) await new Promise(r => setTimeout(r, 2000));
    }
  }

  function renderTable() {
    const tbody = document.getElementById('page-stats-body');
    const search = document.getElementById('stats-search').value.toLowerCase();
    const sort = document.getElementById('stats-sort').value;

    let filtered = fullStatsList.filter(p => p.label.toLowerCase().includes(search) || p.url.toLowerCase().includes(search));
    
    if (sort === 'visits') filtered.sort((a,b) => b.count - a.count);
    else filtered.sort((a,b) => a.label.localeCompare(b.label));

    tbody.innerHTML = filtered.map(p => `
      <tr>
        <td>
          <div style="font-weight: 600;">${p.label}</div>
          <div style="font-size: 0.75rem; color: var(--color-muted);">${p.url || ''}</div>
        </td>
        <td class="count-cell">${p.count.toLocaleString()}</td>
      </tr>
    `).join('');
  }

  document.getElementById('stats-search').addEventListener('input', renderTable);
  document.getElementById('stats-sort').addEventListener('change', renderTable);

  loadInitialStats();
</script>
