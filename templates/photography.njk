---
layout: page.njk
---
{% if heroImage %}
<div class="home-hero-wrapper">
  <div class="home-slideshow-fs">
    <img src="{{ heroImage }}" alt="{{ title }}" class="img-cover">
  </div>
  <section class="home-hero-overlay">
    <h1 class="home-title">{{ title }}</h1>
    <p class="home-intro">{{ description }}</p>
    <div class="scroll-hint">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 13l5 5 5-5M7 6l5 5 5-5"/></svg>
    </div>
  </section>
</div>
{% else %}
<div class="page-intro">
  <h1>{{ title }}</h1>
  <p class="page-lead">{{ description }}</p>
</div>
{% endif %}

<div class="standard-page">
  {% if content %}
  <div class="post-content">{{ content | safe }}</div>
  {% endif %}

  {% if collections.featuredGalleries and collections.featuredGalleries.length %}
  <p class="section-label">Featured Galleries</p>
  <div class="story-list">
    {% for gallery in collections.featuredGalleries | limit(3) %}
    <a href="{{ gallery.url | url }}" class="story-card" data-tags="{{ gallery.data.tags | join(',') if gallery.data.tags else '' }}">
      <div class="story-card-img">
        {% if gallery.data.coverImage %}
        <img src="{{ gallery.data.coverImage }}" alt="{{ gallery.data.title }}" loading="lazy">
        {% endif %}
      </div>
      <div class="story-card-body">
        <div class="post-card-meta">
          {% if gallery.date %}<time class="post-card-date" datetime="{{ gallery.date | isoDate }}">{{ gallery.date | readableDate }}</time>{% endif %}
          {% if gallery.data.tags %}
          <div class="post-card-tags">
            {% for tag in gallery.data.tags | limit(2) %}<span class="tag">{{ tag }}</span>{% endfor %}
          </div>
          {% endif %}
        </div>
        <div class="gallery-card-title-row">
          <span class="story-card-title">{{ gallery.data.title }}</span>
          {% if gallery.data.prints %}
          {% set printStatuses = gallery.data.prints | ensureArray %}
          <div class="gallery-card-prints">
            {% for status in printStatuses %}
            {% set s = status | upper %}
            <div class="print-pill {{ 'available' if s == 'P' else ('exclusive' if s == 'E' else 'private') }}" data-tooltip="{{ 'Available for Prints' if s == 'P' else ('Exclusivity Deal in Place' if s == 'E' else 'Not Available for Prints') }}">
              {% if s == 'P' %}<svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"></polyline><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"></path><rect x="6" y="14" width="12" height="8"></rect></svg>
              {% elif s == 'E' %}<svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg>
              {% elif s == 'X' %}<svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>{% endif %}
            </div>
            {% endfor %}
          </div>
          {% endif %}
        </div>
        {% if gallery.data.excerpt %}
        <div class="story-card-desc">{{ gallery.data.excerpt }}</div>
        {% endif %}
      </div>
    </a>
    {% endfor %}
  </div>
  {% endif %}

  {% if collections.regularGalleries and collections.regularGalleries.length %}
  <p class="section-label">Galleries</p>
  
  <div class="filter-container">
    <div class="filter-cloud collapsed" id="filter-cloud">
      <button class="filter-btn active" data-filter="all">All</button>
      {% for tag in collections.galleries | getAllTags %}
      <button class="filter-btn" data-filter="{{ tag }}">{{ tag }}</button>
      {% endfor %}
    </div>
    <div class="show-more-wrapper" id="show-more-wrapper">
      <button class="show-more-btn" id="show-more-btn">
        <span>MORE TAGS</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
      </button>
    </div>
  </div>

  <div class="gallery-grid" id="gallery-grid">
    {% for gallery in collections.regularGalleries %}
    <a href="{{ gallery.url | url }}" class="gallery-card" data-tags="{{ gallery.data.tags | join(',') if gallery.data.tags else '' }}">
      <div class="gallery-card-img">
        {% if gallery.data.coverImage %}
        <img src="{{ gallery.data.coverImage }}" alt="{{ gallery.data.title }}" loading="lazy">
        {% endif %}
      </div>
      <div class="gallery-card-body">
        <div class="post-card-meta">
          {% if gallery.date %}<time class="post-card-date" datetime="{{ gallery.date | isoDate }}">{{ gallery.date | readableDate }}</time>{% endif %}
          {% if gallery.data.tags %}
          <div class="post-card-tags">
            {% for tag in gallery.data.tags | limit(2) %}<span class="tag">{{ tag }}</span>{% endfor %}
          </div>
          {% endif %}
        </div>
        <div class="gallery-card-title-row">
          <span class="gallery-card-title">{{ gallery.data.title }}</span>
          {% if gallery.data.prints %}
          {% set printStatuses = gallery.data.prints | ensureArray %}
          <div class="gallery-card-prints">
            {% for status in printStatuses %}
            {% set s = status | upper %}
            <div class="print-pill {{ 'available' if s == 'P' else ('exclusive' if s == 'E' else 'private') }}" data-tooltip="{{ 'Available for Prints' if s == 'P' else ('Exclusivity Deal in Place' if s == 'E' else 'Not Available for Prints') }}">
              {% if s == 'P' %}<svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"></polyline><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"></path><rect x="6" y="14" width="12" height="8"></rect></svg>
              {% elif s == 'E' %}<svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg>
              {% elif s == 'X' %}<svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>{% endif %}
            </div>
            {% endfor %}
          </div>
          {% endif %}
        </div>
        {% if gallery.data.excerpt %}
        <div class="story-card-desc">{{ gallery.data.excerpt }}</div>
        {% endif %}
      </div>
    </a>
    {% endfor %}
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const filterBtns = document.querySelectorAll('.filter-btn');
      const grid = document.getElementById('gallery-grid');
      const filterCloud = document.getElementById('filter-cloud');
      const showMoreBtn = document.getElementById('show-more-btn');
      const showMoreWrapper = document.getElementById('show-more-wrapper');
      
      if (!grid) return;
      const galleryCards = grid.querySelectorAll('.gallery-card');

      // Check if "More" button is needed
      const checkOverflow = () => {
        if (!filterCloud) return;
        if (filterCloud.scrollHeight > filterCloud.clientHeight + 5) {
          showMoreWrapper.style.display = 'flex';
        } else if (!filterCloud.classList.contains('collapsed')) {
          filterCloud.classList.add('collapsed');
          const wouldOverflow = filterCloud.scrollHeight > filterCloud.clientHeight + 5;
          filterCloud.classList.remove('collapsed');
          if (!wouldOverflow) showMoreWrapper.style.display = 'none';
        } else {
          showMoreWrapper.style.display = 'none';
        }
      };

      checkOverflow();
      window.addEventListener('resize', checkOverflow);

      showMoreBtn.addEventListener('click', () => {
        const isCollapsed = filterCloud.classList.contains('collapsed');
        if (isCollapsed) {
          filterCloud.style.maxHeight = filterCloud.scrollHeight + 'px';
          filterCloud.classList.remove('collapsed');
        } else {
          filterCloud.style.maxHeight = '74px';
          filterCloud.classList.add('collapsed');
        }
        showMoreBtn.classList.toggle('expanded', isCollapsed);
        showMoreBtn.querySelector('span').textContent = isCollapsed ? 'FEWER TAGS' : 'MORE TAGS';
      });

      filterBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          if (btn.classList.contains('active')) return;

          const filter = btn.getAttribute('data-filter');
          
          // Start fade out ONLY on grid
          grid.classList.add('filtering');

          setTimeout(() => {
            // Update active state
            filterBtns.forEach(b => b.classList.remove('active'));
            btn.classList.add('active');

            // Filter cards inside the grid
            galleryCards.forEach(card => {
              const tagsAttr = card.getAttribute('data-tags');
              const tags = tagsAttr ? tagsAttr.split(',') : [];
              const isMatch = filter === 'all' || tags.includes(filter);
              card.style.display = isMatch ? 'flex' : 'none';
            });

            // Trigger fade in
            grid.classList.remove('filtering');
          }, 300);
        });
      });
    });
  </script>
  {% endif %}

  {% if collections.photoStories and collections.photoStories.length %}
  <p class="section-label">Photo Stories</p>
  <div class="story-list">
    {% for story in collections.photoStories %}
    <a href="{{ story.url | url }}" class="story-card">
      <div class="story-card-img">
        {% if story.data.coverImage %}
        <img src="{{ story.data.coverImage }}" alt="{{ story.data.title }}" loading="lazy">
        {% endif %}
      </div>
      <div class="story-card-body">
        <div class="post-card-meta">
          {% if story.date %}<time class="post-card-date" datetime="{{ story.date | isoDate }}">{{ story.date | readableDate }}</time>{% endif %}
          {% if story.data.tags %}
          <div class="post-card-tags">
            {% for tag in story.data.tags | limit(2) %}<span class="tag">{{ tag }}</span>{% endfor %}
          </div>
          {% endif %}
        </div>
        <div class="story-card-title">{{ story.data.title }}</div>
        {% if story.data.excerpt %}
        <div class="story-card-desc">{{ story.data.excerpt }}</div>
        {% endif %}
      </div>
    </a>
    {% endfor %}
  </div>
  {% endif %}
</div>
