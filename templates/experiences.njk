<!-- Shared Booking Modal -->
<div class="enquiry-backdrop" id="exp-backdrop" aria-hidden="true"></div>
<div class="enquiry-modal" id="exp-modal" role="dialog" aria-modal="true" aria-label="Booking enquiry">
  <button class="enquiry-close" id="exp-close" aria-label="Close">
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
  </button>

  <div class="enquiry-form-wrap" id="exp-form-wrap">
    <p class="enquiry-eyebrow" id="exp-modal-eyebrow">Guided Walk Enquiry</p>
    <h2 class="enquiry-heading">Get in Touch</h2>
    <p class="enquiry-subhead" id="exp-modal-subhead">Free, informal walks in the Squamish Estuary. Tell me a bit about yourself and when you'd like to go.</p>

    <form class="enquiry-form" id="exp-form" novalidate>
      <input type="hidden" name="access_key" id="exp-access-key" value="75a0cde8-cec2-4985-b2b2-86f74ffe271e">
      <input type="hidden" name="subject" id="exp-subject" value="Guided Walk Enquiry from niallbell.com">
      <input type="checkbox" name="botcheck" style="display:none">

      <div class="enquiry-field">
        <label class="enquiry-label" for="exp-name">Your Name</label>
        <input class="enquiry-input" type="text" id="exp-name" name="name" autocomplete="name" placeholder="Jane Smith" required>
      </div>

      <div class="enquiry-field">
        <label class="enquiry-label" for="exp-email">Email Address</label>
        <input class="enquiry-input" type="email" id="exp-email" name="email" autocomplete="email" placeholder="jane@example.com" required>
      </div>

      <div class="enquiry-field" id="exp-skill-field" style="display:none;">
        <label class="enquiry-label" for="exp-skill">Experience Level</label>
        <select class="enquiry-input" id="exp-skill" name="skill_level">
          <option value="">Select one…</option>
          <option>Complete beginner: brand new camera</option>
          <option>Intermediate: comfortable with the basics</option>
          <option>Experienced: looking to improve specific skills</option>
        </select>
      </div>

      <div class="enquiry-field">
        <label class="enquiry-label" for="exp-message" id="exp-message-label">Anything else? <span class="enquiry-optional">Optional</span></label>
        <textarea class="enquiry-input enquiry-textarea" id="exp-message" name="message" rows="4" id="exp-message" placeholder="Preferred dates, group size, what you're hoping to see…"></textarea>
      </div>

      <p class="enquiry-error" id="exp-error" aria-live="polite"></p>

      <button type="submit" class="enquiry-submit" id="exp-submit">
        <span class="enquiry-submit-text">Send Enquiry</span>
        <svg class="enquiry-spinner" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg>
      </button>
    </form>
  </div>

  <div class="enquiry-thanks" id="exp-thanks" aria-live="polite">
    <div class="enquiry-thanks-icon">
      <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
    </div>
    <h2 class="enquiry-thanks-heading">Message Sent</h2>
    <p class="enquiry-thanks-body" id="exp-thanks-body">Thanks! I'll be in touch soon to arrange a time.</p>
    <button type="button" class="enquiry-thanks-close" id="exp-thanks-close">Close</button>
  </div>
</div>

<script>
  (() => {
    const wrap = document.getElementById('exp-testimonials');
    const track = wrap && wrap.querySelector('.exp-testimonial-track');
    if (!track) return;
    const originals = [...track.querySelectorAll('.exp-testimonial-card')];
    if (originals.length <= 1) return;

    originals.forEach(c => track.appendChild(c.cloneNode(true)));

    const count = originals.length;
    const GAP = 24; // matches CSS gap: 1.5rem
    let current = 0;
    let animating = false;

    function stepPx() {
      return (wrap.offsetWidth + GAP) / 2;
    }

    function moveTo(idx, animated) {
      if (!animated) track.style.transition = 'none';
      track.style.transform = `translateX(-${idx * stepPx()}px)`;
      if (!animated) {
        track.getBoundingClientRect(); // force reflow
        track.style.transition = '';
      }
    }

    track.addEventListener('transitionend', () => {
      if (current >= count) {
        current = 0;
        moveTo(0, false);
      }
      animating = false;
    });

    function advance() {
      if (animating) return;
      animating = true;
      current++;
      moveTo(current, true);
    }

    // Recalculate position on resize without animating
    new ResizeObserver(() => moveTo(current, false)).observe(wrap);

    setInterval(advance, 5000);
  })();

  (() => {
    const WALKS = {
      eyebrow: 'Guided Walk Enquiry',
      subhead: 'Free, informal walks in the Squamish Estuary. Tell me a bit about yourself and when you\'d like to go.',
      accessKey: '75a0cde8-cec2-4985-b2b2-86f74ffe271e',
      subject: 'Guided Walk Enquiry from niallbell.com',
      messagePlaceholder: 'Preferred dates, group size, what you\'re hoping to see…',
      thanksBody: 'Thanks! I\'ll be in touch soon to arrange a walk.',
      heroEyebrow: 'Guided Wildlife Walks',
      showSkill: false,
    };
    const WORKSHOPS = {
      eyebrow: 'Workshop Enquiry',
      subhead: 'Small groups and 1:1 sessions in the field. Tell me about your goals and I\'ll come back with availability.',
      accessKey: '0de91db6-157a-4b86-bf50-f41ca2c3a5b9',
      subject: 'Photography Workshop Enquiry from niallbell.com',
      messagePlaceholder: 'Experience level, goals, preferred dates, group size…',
      thanksBody: 'Thanks! I\'ll be in touch soon with availability and details.',
      heroEyebrow: 'Photography Workshops',
      showSkill: true,
    };

    let currentMode = 'walks';

    const walksSection = document.getElementById('exp-walks');
    const workshopsSection = document.getElementById('exp-workshops');
    const toggleBtns = document.querySelectorAll('.exp-toggle-btn');
    const heroEyebrow = document.getElementById('exp-hero-eyebrow');

    const modal = document.getElementById('exp-modal');
    const backdrop = document.getElementById('exp-backdrop');
    const closeBtn = document.getElementById('exp-close');
    const formWrap = document.getElementById('exp-form-wrap');
    const thanks = document.getElementById('exp-thanks');
    const thanksClose = document.getElementById('exp-thanks-close');
    const form = document.getElementById('exp-form');
    const submitBtn = document.getElementById('exp-submit');
    const errorEl = document.getElementById('exp-error');

    function setMode(mode) {
      currentMode = mode;
      const cfg = mode === 'walks' ? WALKS : WORKSHOPS;
      const outgoing = mode === 'walks' ? workshopsSection : walksSection;
      const incoming = mode === 'walks' ? walksSection : workshopsSection;

      // Fade out outgoing, swap display, fade in incoming
      outgoing.style.opacity = '0';
      setTimeout(() => {
        outgoing.classList.add('exp-hidden');
        outgoing.style.opacity = '';
        incoming.classList.remove('exp-hidden');
        incoming.style.transition = 'none';
        incoming.style.opacity = '0';
        incoming.getBoundingClientRect(); // force reflow
        incoming.style.transition = '';
        incoming.style.opacity = '1';
      }, 350);

      // Toggle buttons
      toggleBtns.forEach(btn => {
        btn.classList.toggle('active', btn.dataset.mode === mode);
      });

      // Hero eyebrow
      if (heroEyebrow) heroEyebrow.textContent = cfg.heroEyebrow;
    }

    toggleBtns.forEach(btn => {
      btn.addEventListener('click', () => setMode(btn.dataset.mode));
    });

    function openModal() {
      const cfg = currentMode === 'walks' ? WALKS : WORKSHOPS;
      document.getElementById('exp-modal-eyebrow').textContent = cfg.eyebrow;
      document.getElementById('exp-modal-subhead').textContent = cfg.subhead;
      document.getElementById('exp-access-key').value = cfg.accessKey;
      document.getElementById('exp-subject').value = cfg.subject;
      document.getElementById('exp-message').placeholder = cfg.messagePlaceholder;
      document.getElementById('exp-thanks-body').textContent = cfg.thanksBody;
      document.getElementById('exp-skill-field').style.display = cfg.showSkill ? '' : 'none';

      formWrap.style.display = '';
      thanks.classList.remove('visible');
      form.reset();
      errorEl.textContent = '';
      modal.classList.add('open');
      backdrop.classList.add('open');
      document.body.style.overflow = 'hidden';
      document.getElementById('exp-name').focus();
    }

    function closeModal() {
      modal.classList.remove('open');
      backdrop.classList.remove('open');
      document.body.style.overflow = '';
    }

    document.getElementById('walks-enquiry-open').addEventListener('click', openModal);
    document.getElementById('workshops-enquiry-open').addEventListener('click', openModal);
    closeBtn.addEventListener('click', closeModal);
    thanksClose.addEventListener('click', closeModal);
    backdrop.addEventListener('click', closeModal);
    document.addEventListener('keydown', e => {
      if (e.key === 'Escape' && modal.classList.contains('open')) closeModal();
    });

    form.addEventListener('submit', async e => {
      e.preventDefault();
      errorEl.textContent = '';
      submitBtn.classList.add('loading');
      submitBtn.disabled = true;
      try {
        const res = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          body: new FormData(form),
        });
        const json = await res.json();
        if (json.success) {
          formWrap.style.display = 'none';
          thanks.classList.add('visible');
        } else {
          errorEl.textContent = json.message || 'Something went wrong — please try again.';
        }
      } catch {
        errorEl.textContent = 'Could not send — please check your connection and try again.';
      } finally {
        submitBtn.classList.remove('loading');
        submitBtn.disabled = false;
      }
    });
  })();
</script>
