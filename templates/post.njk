---
layout: base.njk
---
<article class="post">
  <header class="post-header">
    <h1>{{ title }}</h1>
    {% if date %}
    <div class="post-meta">
      <time datetime="{{ date | isoDate }}">{{ date | readableDate }}</time>
      {% if tags and tags.length %}
        &middot;
        {% for tag in tags %}
          <span class="tag">{{ tag }}</span>
        {% endfor %}
      {% endif %}
    </div>
    {% endif %}
  </header>

  <div class="post-content">
    {{ content | safe }}
  </div>
</article>
