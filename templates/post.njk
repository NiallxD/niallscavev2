---
layout: page.njk
---
{% if heroImage %}
<div class="home-hero-wrapper">
  <div class="home-slideshow-fs">
    <img src="{{ heroImage }}" alt="{{ title }}" style="width: 100%; height: 100%; object-fit: cover; display: block;">
  </div>
  <section class="home-hero-overlay">
    <h1 class="home-title">{{ title }}</h1>
    {% if description %}<p class="home-intro">{{ description }}</p>{% endif %}
    <div class="post-meta" style="margin-top: 1rem;">
      {% if date %}<time datetime="{{ date | isoDate }}" style="color: rgba(255, 255, 255, 0.8);">{{ date | readableDate }}</time>{% endif %}
      {% if tags and tags.length %}
        {% for tag in tags %}<span class="tag" style="background: rgba(255, 255, 255, 0.15); border-color: transparent; color: #fff;">{{ tag }}</span>{% endfor %}
      {% endif %}
    </div>
  </section>
</div>
{% endif %}

<article class="post">
  <div class="post-body">
    {% if not heroImage %}
    <header class="post-header">
      <h1>{{ title }}</h1>
      <div class="post-meta">
        {% if date %}<time datetime="{{ date | isoDate }}">{{ date | readableDate }}</time>{% endif %}
        {% if tags and tags.length %}
          {% for tag in tags %}<span class="tag">{{ tag }}</span>{% endfor %}
        {% endif %}
      </div>
    </header>
    {% endif %}
    <div class="post-content">{{ content | safe }}</div>
  </div>
</article>
