<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if title %}{{ title }} — {% endif %}Niall Bell</title>
  {% if description %}<meta name="description" content="{{ description }}">{% endif %}
  {% if noindex %}<meta name="robots" content="noindex, nofollow">{% else %}<meta name="robots" content="noarchive">{% endif %}
  <!-- Privacy & Security -->
  <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; font-src 'self' data:; img-src 'self' data: https://i.imgur.com https://*.basemaps.cartocdn.com https://m.media-amazon.com; connect-src https://api.web3forms.com https://niallxd--110a558a4a6d11f191a4ee650bb23af1.web.val.run; frame-src https://*.youtube.com https://*.vimeo.com https://*.kuula.co;">
  <meta name="referrer" content="no-referrer">
  
  <!-- Anti-AI Scraping -->
  <meta name="ai-content" content="noai, noimageai">
  <meta name="CCBot" content="nofollow">
  <meta property="og:title" content="{% if title %}{{ title }} — {% endif %}Niall Bell">
  {% if description %}<meta property="og:description" content="{{ description }}">{% endif %}
  {% if coverImage %}<meta property="og:image" content="{{ coverImage }}">{% endif %}
  <link rel="stylesheet" href="{{ '/static/css/style.css?v=1.1' | url }}">
  <script>
    const savedTheme = localStorage.getItem('theme');
    if (savedTheme === 'dark') {
      document.documentElement.setAttribute('data-theme', 'dark');
    }
  </script>
  {% block head %}{% endblock %}
</head>
<body>
  <header class="site-header{% if page.url == '/' or heroImage or heroVideo or isGalleryView %} transparent-header{% endif %}">
    <div class="site-header-inner">
      <a class="site-title" href="{{ '/' | url }}">
        <img src="{{ '/static/images/Logo_Black_Large.png' | url }}" alt="Niall Bell" class="site-logo logo-black">
        <img src="{{ '/static/images/Logo_White_Large.png' | url }}" alt="Niall Bell" class="site-logo logo-white">
      </a>
      <nav class="nav-menu">
        <a href="{{ '/photography/' | url }}"{% if page.url and '/photography/' in page.url %} class="active"{% endif %}>Photo</a>
        <a href="{{ '/videography/' | url }}"{% if page.url and '/videography/' in page.url %} class="active"{% endif %}>Video</a>
        <a href="{{ '/prints/' | url }}"{% if page.url == '/prints/' %} class="active"{% endif %}>Prints</a>
        <a href="{{ '/blog/' | url }}"{% if page.url == '/blog/' %} class="active"{% endif %}>Writing</a>
        <a href="{{ '/side-projects/' | url }}"{% if page.url == '/side-projects/' %} class="active"{% endif %}>Projects</a>
        <a href="{{ '/bookshelf/' | url }}"{% if page.url == '/bookshelf/' %} class="active"{% endif %}>Bookshelf</a>
        <a href="{{ '/about-me/' | url }}"{% if page.url == '/about-me/' %} class="active"{% endif %}>About</a>
      </nav>
      <div class="header-controls">
        <button id="theme-toggle" class="theme-toggle" aria-label="Toggle dark mode">
          <svg class="sun-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line><line x1="1" y1="12" x2="3" y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line></svg>
          <svg class="moon-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
        </button>
        <button id="menu-toggle" class="menu-toggle" aria-label="Toggle menu">
          <svg class="menu-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
          <svg class="close-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
        </button>
      </div>
    </div>
  </header>
  <div class="nav-overlay"></div>

  <main>
    {{ content | safe }}
  </main>

  <footer class="site-footer">
    <div class="site-footer-inner">
      <div class="footer-col brand">
        <a class="footer-logo" href="{{ '/' | url }}">
          <img src="{{ '/static/images/Logo_Black_Large.png' | url }}" alt="Niall Bell" class="site-logo logo-black">
          <img src="{{ '/static/images/Logo_White_Large.png' | url }}" alt="Niall Bell" class="site-logo logo-white">
        </a>
        <p class="footer-web-address">niallbell.com</p>
        <div class="footer-contact">
          <div class="contact-item">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="contact-icon"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            <span class="reveal-email" data-u="niall" data-d="niallbell.com" style="cursor:pointer;">Click to reveal email</span>
          </div>
          <div class="contact-item">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="contact-icon"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <span>Squamish, BC</span>
          </div>
        </div>
      </div>
      
      <div class="footer-col sitemap">
        <p class="section-label">Site Map</p>
        <div class="footer-links-list footer-links-two-col">
          <a href="{{ '/photography/' | url }}">Photo</a>
          <a href="{{ '/videography/' | url }}">Video</a>
          <a href="{{ '/prints/' | url }}">Prints</a>
          <a href="{{ '/blog/' | url }}">Writing</a>
          <a href="{{ '/side-projects/' | url }}">Projects</a>
          <a href="{{ '/bookshelf/' | url }}">Bookshelf</a>
          <a href="{{ '/about-me/' | url }}">About</a>
          <a href="{{ '/now/' | url }}">Now</a>
        </div>
        
        <p class="section-label" style="margin-top: 1.5rem !important;">Transparency</p>
        <div class="footer-links-list">
          <a href="{{ '/site-activity/' | url }}" style="color: var(--color-accent);">Site Activity</a>
          <a href="{{ '/the-vault-stats/' | url }}" style="color: var(--color-accent);">Transparency</a>
        </div>
      </div>

      <div class="footer-col legal">
        <p class="section-label">Legal</p>
        <p class="copyright">© {{ "" | year }} Niall Bell</p>
        <p class="copyright-notice">All photographs protected by international copyright laws. No unauthorised use.</p>
      </div>
    </div>
  </footer>

  <div id="image-protection-toast" class="image-protection-toast">
	  <a href="mailto:niall@niallbell.com">Get in touch</a> for photo licensing.
  </div>

  <script>
    const themeToggle = document.getElementById('theme-toggle');
    themeToggle.addEventListener('click', () => {
      const current = document.documentElement.getAttribute('data-theme');
      const target = current === 'dark' ? 'light' : 'dark';
      document.documentElement.setAttribute('data-theme', target);
      localStorage.setItem('theme', target);
    });

    const menuToggle = document.getElementById('menu-toggle');
    const navMenu = document.querySelector('.nav-menu');
    const navOverlay = document.querySelector('.nav-overlay');
    const body = document.body;

    const toggleMenu = () => {
      const isOpen = body.classList.toggle('menu-open');
      menuToggle.setAttribute('aria-expanded', isOpen);
    };

    menuToggle.addEventListener('click', toggleMenu);
    navOverlay.addEventListener('click', toggleMenu);

    // Close menu when a link is clicked
    const navLinks = document.querySelectorAll('.nav-menu a');
    navLinks.forEach(link => {
      link.addEventListener('click', () => {
        if (body.classList.contains('menu-open')) {
          toggleMenu();
        }
      });
    });

    const header = document.querySelector('.site-header');
    const onScroll = () => {
      if (window.scrollY > 10) {
        header.classList.add('scrolled');
      } else {
        header.classList.remove('scrolled');
      }
    };
    window.addEventListener('scroll', onScroll);
    onScroll(); // trigger immediately on load

    // Private visit tracking (Val.town SQLite)
    if (!window.location.hostname.includes('localhost') && !window.location.hostname.includes('127.0.0.1')) {
      fetch('https://niallxd--110a558a4a6d11f191a4ee650bb23af1.web.val.run', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ url: window.location.href, title: document.title })
      }).catch(() => {});
    }

    // Right-click protection for images
    document.addEventListener('DOMContentLoaded', () => {
      const toast = document.getElementById('image-protection-toast');
      let toastTimeout;

      const showToast = (e) => {
        if (e.target.tagName && e.target.tagName.toUpperCase() === 'IMG') {
          e.preventDefault();
          
          toast.classList.add('show');
          clearTimeout(toastTimeout);
          toastTimeout = setTimeout(() => {
            toast.classList.remove('show');
          }, 3000);
          return true;
        }
        return false;
      };

      document.addEventListener('contextmenu', showToast, false);
      
      // Handle mobile long-press
      let touchTimer;
      document.addEventListener('touchstart', (e) => {
        if (e.target.tagName && e.target.tagName.toUpperCase() === 'IMG') {
          touchTimer = setTimeout(() => {
            showToast(e);
          }, 500); // 500ms for long press
        }
      }, { passive: false });

      document.addEventListener('touchend', () => {
        clearTimeout(touchTimer);
      }, false);

      document.querySelectorAll('.reveal-email').forEach(el => {
        el.addEventListener('click', () => {
          const email = el.dataset.u + '@' + el.dataset.d;
          // Keep classes like 'text-accent' but remove 'reveal-email'
          const cls = el.className.replace('reveal-email', '').trim();
          const inner = el.querySelector('svg')
            ? el.querySelector('svg').outerHTML + email
            : email;
          const style = el.getAttribute('style') || '';
          el.outerHTML = `<a href="mailto:${email}" class="${cls}" style="${style}">${inner}</a>`;
        });
      });
    });
  </script>
</body>
</html>
