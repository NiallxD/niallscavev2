<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if title %}{{ title }} — {% endif %}Niall Bell</title>
  {% if description %}<meta name="description" content="{{ description }}">{% endif %}
  <meta property="og:title" content="{% if title %}{{ title }} — {% endif %}Niall Bell">
  {% if description %}<meta property="og:description" content="{{ description }}">{% endif %}
  {% if page.url %}<meta property="og:url" content="https://niallxd.github.io/niallscavev2{{ page.url }}">{% endif %}
  <link rel="stylesheet" href="/static/css/style.css">
</head>
<body>
  <header class="site-header">
    <a class="site-title" href="/">Niall Bell</a>
    <nav>
      <a href="/blog" {% if page.url == '/blog/' %}class="active"{% endif %}>Writing</a>
      <a href="/photography" {% if page.url and '/photography' in page.url %}class="active"{% endif %}>Photography</a>
      <a href="/bookshelf" {% if page.url == '/bookshelf/' %}class="active"{% endif %}>Bookshelf</a>
      <a href="/about-me" {% if page.url == '/about-me/' %}class="active"{% endif %}>About</a>
    </nav>
  </header>

  <main>
    {{ content | safe }}
  </main>

  <footer class="site-footer">
    <span>© 2025 Niall Bell</span>
    <div class="footer-links">
      <a href="mailto:niall@niallbell.com">Email</a>
    </div>
  </footer>
</body>
</html>
