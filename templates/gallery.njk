---
layout: page.njk
---
{% block head %}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fancyapps/ui@5/dist/fancybox/fancybox.css"/>
{% endblock %}

<article class="gallery-page">
  <header class="page-header">
    <h1>{{ title }}</h1>
    {% if tags and tags.length %}
    <div class="post-meta">
      {% for tag in tags %}<span class="tag">{{ tag }}</span>{% endfor %}
    </div>
    {% endif %}
    {% if description %}<p class="page-lead">{{ description }}</p>{% endif %}
  </header>
  <div class="gallery-body">{{ content | safe }}</div>
</article>

<script src="https://cdn.jsdelivr.net/npm/@fancyapps/ui@5/dist/fancybox/fancybox.umd.js"></script>
<script>Fancybox.bind('[data-fancybox]', { groupAll: false, Thumbs: false });</script>
